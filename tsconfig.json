{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2022",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "importHelpers": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "lib": ["DOM", "ES2022"],
    "paths": {
      "@types": ["./src/types.ts"]
    }
  },
  "include": ["src/**/*.ts", "jest.config.ts", "esbuild.config.ts", "version-bump.ts"],
  "exclude": ["**/*.test.ts", ".direnv"]
}
