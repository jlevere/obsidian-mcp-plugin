{
  "name": "obsidian-mcp-plugin",
  "version": "0.0.10",
  "description": "Allow an AI to interact with your vault's notes through a self-contained MCP server",
  "main": "dist/main.js",
  "types": "main.d.ts",
  "engines": {
    "node": "^22.14.0"
  },
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "npx tsx esbuild.config.ts watch",
    "build": "pnpm tsc -noEmit -skipLibCheck && npx tsx esbuild.config.ts production",
    "build:dev": "pnpm tsc -noEmit -skipLibCheck && npx tsx esbuild.config.ts",
    "test": "pnpm jest",
    "lint": "pnpm eslint",
    "preversion": "pnpm lint && pnpm build",
    "postversion": "tsx version-bump.ts",
    "postpublish": "git push --follow-tags",
    "inspect": "npx @modelcontextprotocol/inspector",
    "package": "pnpm build && zip plugin.zip dist/main.js manifest.json",
    "format:write": "pnpm prettier --write \"*.ts\" \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "pnpm prettier --check \"*.ts\" \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "obsidian",
    "mcp",
    "ai",
    "plugin"
  ],
  "author": "jlevere",
  "license": "MIT",
  "devDependencies": {
    "@esbuild-plugins/tsconfig-paths": "^0.1.2",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@modelcontextprotocol/inspector": "^0.21.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.19",
    "builtin-modules": "^5.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "jiti": "^2.7.0",
    "obsidian": "^1.12.3",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "ts-jest": "^29.4.11",
    "tslib": "^2.8.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "dependencies": {
    "@dmitryrechkin/json-schema-to-zod": "^1.0.1",
    "ajv": "^8.20.0",
    "diff": "^9.0.0",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "overrides": {
      "@eslint/plugin-kit@<0.3.4": ">=0.3.4",
      "ajv@<6.14.0": ">=6.14.0",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=2 <2.1.0": ">=2.1.0",
      "diff@>=4.0.0 <4.0.4": ">=4.0.4",
      "fast-uri@<=3.1.1": ">=3.1.2",
      "flatted@<3.4.2": ">=3.4.2",
      "form-data@<4.0.5": ">=4.0.5",
      "js-yaml@<4.1.1": ">=4.1.1",
      "lodash@<4.18.0": ">=4.18.0",
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch@>=8 <9.0.9": ">=9.0.9",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "picomatch@<2.3.2": ">=2.3.2",
      "qs@<6.15.2": ">=6.15.2",
      "ws@<8.20.1": ">=8.20.1"
    }
  }
}
